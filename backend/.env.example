# Server Configuration
NODE_ENV=development
PORT=5000

# Database Configuration (Prisma)
DATABASE_URL=postgresql://postgres:password@localhost:5432/finance_dashboard?schema=public

# Supabase Configuration (Optional - only if using Supabase features)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# JWT Configuration
JWT_ACCESS_SECRET=your_super_secret_access_token_key_minimum_32_characters
JWT_REFRESH_SECRET=your_super_secret_refresh_token_key_minimum_32_characters
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# CORS Configuration
FRONTEND_URL=http://localhost:5173
# Optional: comma-separated list of allowed origins (overrides FRONTEND_URL)
# Example: CORS_ORIGINS=http://localhost:5173,http://localhost:3000
# CORS_ORIGINS=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
